{
  "name": "@navikt/ft-form-hooks",
  "description": "Overbygg over react-hook-form. Tilbyr form-komponenter som radioknapp og textarea",
  "version": "12.4.1",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest --project=jsdom",
    "test:browser": "vitest --project=browser",
    "eslint": "eslint src/**/*.ts* --color",
    "eslint:fix": "eslint --fix src/**/*.ts* --color",
    "prettier:fix": "prettier --write src",
    "tsc": "tsc --pretty",
    "stylelint": "stylelint src/**/*.module.css",
    "dev": "vite build --watch --mode development",
    "clean": "rm -rf ./dist ./node_modules"
  },
  "peerDependencies": {
    "@navikt/aksel-icons": "8.x",
    "@navikt/ds-react": "8.x",
    "@navikt/ft-ui-komponenter": "8.x",
    "@navikt/ft-utils": "5.x",
    "dayjs": "1.x",
    "react": "19.x",
    "react-dom": "19.x",
    "react-hook-form": "7.x"
  },
  "devDependencies": {
    "@navikt/aksel-icons": "8.13.1",
    "@navikt/ds-react": "8.13.1",
    "@navikt/ft-config-eslint": "workspace:^",
    "@navikt/ft-config-typescript": "workspace:^",
    "@navikt/ft-config-vite": "workspace:^",
    "@navikt/ft-ui-komponenter": "workspace:^",
    "@navikt/ft-utils": "workspace:^",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "dayjs": "1.11.21",
    "eslint": "9.39.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "stylelint": "17.13.0",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vitest": "4.1.9"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/navikt/ft-frontend-saksbehandling",
    "directory": "packages/form-hooks"
  },
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  }
}
