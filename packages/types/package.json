{
  "name": "@navikt/ft-types",
  "description": "Pakke som har typer som blir brukt på tvers av applikasjoner",
  "version": "6.1.1",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "eslint": "eslint src/**/*.ts* --color",
    "eslint:fix": "eslint --fix src/**/*.ts* --color",
    "prettier:fix": "prettier --write src",
    "tsc": "tsc --pretty",
    "dev": "vite build --watch --mode development",
    "clean": "rm -rf ./dist ./node_modules"
  },
  "devDependencies": {
    "@navikt/ft-config-eslint": "workspace:^",
    "@navikt/ft-config-typescript": "workspace:^",
    "@navikt/ft-config-vite": "workspace:^",
    "eslint": "9.39.4",
    "typescript": "6.0.3",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/navikt/ft-frontend-saksbehandling",
    "directory": "packages/types"
  },
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "types": "./dist/index.d.ts"
    }
  }
}
