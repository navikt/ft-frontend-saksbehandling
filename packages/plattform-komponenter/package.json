{
  "name": "@navikt/ft-plattform-komponenter",
  "description": "Pakke som tilbyr sammensatte komponenter som f.eks. menyer",
  "version": "10.6.0",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest --project=jsdom",
    "test:browser": "vitest --project=browser",
    "eslint": "eslint src/**/*.ts* --color",
    "eslint:fix": "eslint --fix src/**/*.ts* --color",
    "prettier:fix": "prettier --write src",
    "tsc": "tsc --pretty",
    "stylelint": "stylelint src/**/*.module.css",
    "dev": "vite build --watch --mode development",
    "clean": "rm -rf ./dist ./node_modules"
  },
  "dependencies": {
    "@popperjs/core": "2.11.8",
    "lodash.throttle": "4.1.1",
    "prop-types": "15.8.1"
  },
  "peerDependencies": {
    "@navikt/aksel-icons": "8.x",
    "@navikt/ds-css": "8.x",
    "@navikt/ds-react": "8.x",
    "@navikt/ft-utils": "workspace:^",
    "dayjs": "1.x",
    "react": "19.x",
    "react-dom": "19.x"
  },
  "devDependencies": {
    "@navikt/aksel-icons": "8.6.0",
    "@navikt/ds-css": "8.6.0",
    "@navikt/ds-react": "8.6.0",
    "@navikt/ft-config-eslint": "workspace:^",
    "@navikt/ft-config-typescript": "workspace:^",
    "@navikt/ft-config-vite": "workspace:^",
    "@navikt/ft-utils": "workspace:^",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "dayjs": "1.11.19",
    "eslint": "9.39.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stylelint": "17.6.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.1.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/navikt/ft-frontend-saksbehandling",
    "directory": "packages/plattform-komponenter"
  },
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  }
}
